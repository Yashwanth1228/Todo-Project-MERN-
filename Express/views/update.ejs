<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Update List</title>
    <link rel="stylesheet" href="/styles.css">

</head>
<body>
  <%- include('navbar') %>
  

  <div class="container">
  <h1>To update list</h1>

    <form class="todo-form" method="post" action="/update/<%= result._id %>">
      <input class="input" value="<%= result.title %>" type="text" placeholder="Enter task Title" name="title"><br><br>
      <textarea class="input" name="description" id=""><%= result.description %></textarea><br><br>
      <button class="btn">Update task</button>
    </form>
  </div>
  
</body>
</html>